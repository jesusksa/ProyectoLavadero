<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="420.0" maxWidth="600.0" minHeight="420.0" minWidth="600.0" prefHeight="420.0" prefWidth="582.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.lavadero.controllers.FiltroTurnosController">
   <children>
      <Pane fx:id="pnFondo" layoutX="50.0" layoutY="35.0" prefHeight="350.0" prefWidth="500.0" stylesheets="@../Styles/global.css" AnchorPane.bottomAnchor="35.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="35.0">
         <children>
            <VBox alignment="CENTER" prefHeight="350.0" prefWidth="500.0" spacing="15.0">
               <children>
                  <Label text="Filtros de busqueda">
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                  </Label>
                  <HBox alignment="CENTER" prefHeight="220.0" prefWidth="500.0" spacing="20.0">
                     <children>
                        <VBox prefHeight="220.0" prefWidth="200.0" spacing="10.0">
                           <children>
                              <Label text="DNI:">
                                 <font>
                                    <Font name="System Bold" size="18.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="txtDni" prefHeight="30.0" prefWidth="200.0" promptText="escriba aqui..." />
                              <Label text="Estado:">
                                 <font>
                                    <Font name="System Bold" size="18.0" />
                                 </font>
                              </Label>
                              <ComboBox fx:id="cboxEstado" prefHeight="30.0" prefWidth="200.0" promptText="Seleccione uno..." />
                              <Label text="Tipo de Vehiculo:">
                                 <font>
                                    <Font name="System Bold" size="18.0" />
                                 </font>
                              </Label>
                              <ComboBox fx:id="cboxVehiculo" prefHeight="30.0" prefWidth="200.0" promptText="Selecciones uno..." />
                           </children>
                        </VBox>
                        <VBox prefHeight="220.0" prefWidth="200.0" spacing="10.0">
                           <children>
                              <Label text="Tipo de Lavado:">
                                 <font>
                                    <Font name="System Bold" size="18.0" />
                                 </font>
                              </Label>
                              <ComboBox fx:id="cboxServicio" prefHeight="30.0" prefWidth="200.0" promptText="Seleccione uno..." />
                              <Label text="Fecha:">
                                 <font>
                                    <Font name="System Bold" size="18.0" />
                                 </font>
                              </Label>
                              <DatePicker fx:id="dtFecha" prefHeight="30.0" prefWidth="200.0" promptText="Seleccine una fecha..." />
                              <Label text="Matricula:">
                                 <font>
                                    <Font name="System Bold" size="18.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="txtMatricula" prefHeight="30.0" prefWidth="200.0" promptText="Escriba aqui..." />
                           </children>
                        </VBox>
                     </children>
                  </HBox>
                  <Button fx:id="btnFiltrar" mnemonicParsing="false" onAction="#filtrar" prefHeight="40.0" prefWidth="100.0" text="Confirmar" />
               </children>
            </VBox>
         </children>
      </Pane>
   </children>
</AnchorPane>
